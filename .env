# Environment Configuration
# Copia questo file a .env e riempilo con i tuoi valori

# Configurazione Flask
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

# Configurazione API (OpenMeteo non richiede API key, ma è pronto per future API)
# Esempio per API future che richiedono autenticazione
# OPENMETEO_API_KEY=your_api_key_here
# WEATHER_API_KEY=your_api_key_here

# Configurazione Database (per futuri sviluppi)
# DATABASE_URL=sqlite:///weather.db
# DATABASE_USER=user
# DATABASE_PASSWORD=password

# Configurazione Cache
CACHE_TTL=3600

# Configurazione Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Logging
LOG_LEVEL=INFO

# Variabili Opzionali
# ENABLE_CACHE=true
# DEBUG_API_CALLS=false
